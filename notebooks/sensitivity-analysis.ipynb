import pandas as pd

df = pd.read_csv(
    "../data/experiment_results.csv"
)

segments = [
    "desktop",
    "mobile"
]

for segment in segments:

    segment_df = (
        df[df["device_category"] == segment]
    )

    results = (
        segment_df.groupby("variant")
                  ["conversion"]
                  .mean()
    )

    print(
        f"\n===== {segment.upper()} ====="
    )

    print(results)
