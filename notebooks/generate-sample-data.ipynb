import pandas as pd
import numpy as np

np.random.seed(42)

n = 10000

df = pd.DataFrame({

    "user_id": range(1, n + 1),

    "session_id": [
        f"S{i}" for i in range(1, n + 1)
    ],

    "variant": np.random.choice(
        ["control", "variant_b"],
        size=n
    ),

    "device_category": np.random.choice(
        ["desktop", "mobile", "tablet"],
        size=n
    ),

    "traffic_source": np.random.choice(
        ["organic", "paid", "direct", "referral"],
        size=n
    ),

    "country": np.random.choice(
        ["US", "UK", "CA", "AU"],
        size=n
    ),

    "conversion": np.random.binomial(
        1,
        0.045,
        size=n
    ),

    "revenue": np.random.gamma(
        2,
        100,
        size=n
    )

})

df.to_csv(
    "../data/experiment_results.csv",
    index=False
)

print(df.head())
