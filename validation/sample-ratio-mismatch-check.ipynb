import pandas as pd
from scipy.stats import chisquare

df = pd.read_csv("../data/experiment_results.csv")

allocation = df["variant"].value_counts()

observed = allocation.values

expected = [
    observed.sum() / 2,
    observed.sum() / 2
]

chi_square, p_value = chisquare(
    observed,
    expected
)

print("Observed Allocation")
print(allocation)

print("\nChi Square:", round(chi_square,4))
print("P Value:", round(p_value,4))

if p_value < 0.05:
    print("Potential Sample Ratio Mismatch")
else:
    print("No Sample Ratio Mismatch Detected")
